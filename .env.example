# Copia este archivo a .env y completa los valores reales
# cp .env.example .env

# Credenciales de acceso a n8n (se configuran en el primer arranque o en Settings > Users)
N8N_OWNER_EMAIL=tu-correo@ejemplo.com
N8N_OWNER_PASSWORD=cambia-esta-clave

# Puerto donde corre n8n (por defecto 5678)
N8N_PORT=5678
